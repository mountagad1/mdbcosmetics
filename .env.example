# MDB Cosmetics — Environment Variables
# Copy this file to .env.local and fill in your values

# Site URL (required for sitemap and OG)
NEXT_PUBLIC_SITE_URL=https://mdbcosmetics.fr

# Optional: Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Optional: Affiliate link base URLs (override product links)
# NEXT_PUBLIC_AMAZON_AFFILIATE_TAG=mdbcosmetics-21
# NEXT_PUBLIC_SEPHORA_AFFILIATE_ID=your-id
